{
  "name": "project-template-react",
  "version": "0.2.1",
  "private": true,
  "dependencies": {
    "@appquality/appquality-design-system": "2.0.12",
    "@appquality/craft-blocks": "^0.1.31",
    "@appquality/languages": "^1.4.5",
    "@datadog/browser-logs": "^3.4.1",
    "@mui/material": "^7.3.2",
    "@reduxjs/toolkit": "^1.8.2",
    "date-fns": "^2.30.0",
    "formik": "^2.2.6",
    "i18n-iso-countries": "7.12.0",
    "i18next": "^20.2.2",
    "i18next-browser-languagedetector": "^6.1.0",
    "lzutf8": "^0.6.0",
    "qs": "^6.14.0",
    "query-string": "^7.0.0",
    "react": "18.3.1",
    "react-app-polyfill": "^2.0.0",
    "react-bootstrap-icons": "^1.4.0",
    "react-dom": "18.3.1",
    "react-gtm-module": "^2.0.11",
    "react-helmet": "^6.1.0",
    "react-i18next": "^11.8.15",
    "react-redux": "^7.2.4",
    "react-router-dom": "^5.2.0",
    "react-select": "^5.10.2",
    "redux": "^4.1.1",
    "redux-saga": "^1.1.3",
    "redux-thunk": "^2.3.0",
    "styled-components": "^6",
    "tippy.js": "^6.3.7",
    "universal-cookie": "^4.0.4",
    "uuid": "^8.3.2",
    "web-vitals": "^1.0.1",
    "yup": "^0.32.9"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "src/**/*.{js,jsx,ts,tsx,json,css,scss,md}": [
      "prettier --write"
    ]
  },
  "scripts": {
    "prepare": "npx husky install",
    "start": "craco start",
    "start:ssl": "craco --openssl-legacy-provider start",
    "build": "craco build",
    "test": "test:e2e:ci",
    "test:e2e:ui": "npx playwright test --ui",
    "test:e2e": "npx playwright test",
    "prettier": "npx prettier --write 'src/**/*.{js,jsx,ts,tsx,json,css,scss,md}'",
    "translate": "i18next-scanner",
    "generate-schema": ". ./.env.development; npx openapi-typescript $REACT_APP_API_URL/reference/ --output src/utils/schema.ts ",
    "generate-api": ". ./.env.development; API_URL=$REACT_APP_API_URL/reference/ npx @rtk-query/codegen-openapi src/services/tryberApi/config.ts",
    "generate-fixtures": ". ./.env.development; API_URL=$REACT_APP_API_URL/reference/; npx @appquality/fixture-generator -u $API_URL && npx prettier --write 'tests/api/**/*.json'"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ],
    "overrides": [
      {
        "files": [
          "**/*.stories.*"
        ],
        "rules": {
          "import/no-anonymous-default-export": "off"
        }
      }
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@appquality/fixture-generator": "^1.0.2",
    "@babel/core": "^7.29.0",
    "@babel/plugin-proposal-private-property-in-object": "^7.21.11",
    "@babel/preset-env": "^7.29.0",
    "@babel/preset-react": "^7.28.5",
    "@craco/craco": "^7.1.0",
    "@currents/playwright": "^0.10.7",
    "@playwright/test": "^1.39.0",
    "@redux-devtools/core": "^3.11.0",
    "@rtk-query/codegen-openapi": "^2.2.0",
    "@types/node": "^14.14.41",
    "@types/qs": "^6.14.0",
    "@types/react": "18.3.1",
    "@types/react-dom": "18.3.1",
    "@types/react-gtm-module": "^2.0.0",
    "@types/react-helmet": "^6.1.1",
    "@types/react-redux": "^7.1.16",
    "@types/react-router-dom": "^5.1.7",
    "@types/react-select": "^4.0.15",
    "@types/react-select-country-list": "^2.2.0",
    "@types/styled-components": "^5.1.9",
    "@types/uuid": "^8.3.1",
    "file-loader": "^6.2.0",
    "husky": "^6.0.0",
    "i18next-scanner": "^3.1.0",
    "i18next-scanner-typescript": "1.0.6",
    "openapi-typescript": "^5.1.1",
    "playwright-i18next-fixture": "^1.0.0",
    "prettier": "^2.3.1",
    "typescript": "4.9.5"
  }
}
